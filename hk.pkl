amends "package://github.com/jdx/hk/releases/download/v1.39.0/hk@1.39.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.39.0/hk@1.39.0#/Builtins.pkl"

// Step definitions
local fmt = new Step {
    glob = List("**/*.rs")
    check = "cargo fmt --check"
    fix = "cargo fmt"
}
local clippy = new Step {
    glob = List("**/*.rs", "Cargo.toml")
    check = "cargo clippy --all-targets -- -D warnings"
}
local test = new Step {
    check = "cargo test --lib"
}
local coverage = new Step {
    // Coverage gate. IO/shell-out modules are excluded (covered by e2e, not unit tests).
    // Keep in sync with .github/workflows/ci.yml.
    check = "CARGO_TARGET_DIR=target/tarpaulin cargo tarpaulin --lib --engine llvm --fail-under 20 --exclude-files src/setup.rs --exclude-files src/connect/deploy.rs --exclude-files src/connect/mod.rs --exclude-files src/daemon/launchd.rs --exclude-files src/daemon/mod.rs --exclude-files src/disconnect.rs --exclude-files src/doctor.rs --exclude-files src/paste.rs --exclude-files src/remote/install.rs --exclude-files src/remote/x11_bridge.rs --exclude-files src/remote/mod.rs --exclude-files src/main.rs"
}
local build_no_default = new Step {
    // Catch --no-default-features build failures locally (Linux cross-compile gate)
    glob = List("**/*.rs", "Cargo.toml")
    check = "CARGO_TARGET_DIR=target/no-default-features cargo build --no-default-features"
}
local deny = new Step {
    glob = List("Cargo.toml", "Cargo.lock")
    check = "cargo deny check"
}
local audit = new Step {
    glob = List("Cargo.lock")
    check = "cargo audit"
}

hooks {
    // Fast (<5s) — every commit
    ["pre-commit"] {
        fix = true
        stash = "git"
        steps {
            ["cargo-fmt"] = fmt
            ["cargo-clippy"] = clippy
            ["cargo-test"] = test
        }
    }
    // Full suite — every push
    ["pre-push"] {
        steps {
            ["cargo-fmt"] = fmt
            ["cargo-clippy"] = clippy
            ["cargo-test"] = test
            ["cargo-coverage"] = coverage
            ["cargo-build-no-default"] = build_no_default
            ["cargo-deny"] = deny
            ["cargo-audit"] = audit
        }
    }
    ["fix"] {
        fix = true
        steps {
            ["cargo-fmt"] = fmt
        }
    }
}
